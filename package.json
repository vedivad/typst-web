{
  "name": "codemirror-typst-linter",
  "workspaces": [
    "demo"
  ],
  "version": "0.1.92",
  "description": "CodeMirror 6 extension for Typst diagnostics with incremental compilation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "import": "./dist/worker.js"
    }
  },
  "files": [
    "dist",
    "THIRD_PARTY_LICENSES"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@codemirror/lint": "^6",
    "@codemirror/state": "^6",
    "@codemirror/view": "^6"
  },
  "dependencies": {
    "@myriaddreamin/typst.ts": "^0.7.0-rc2",
    "@myriaddreamin/typst-ts-web-compiler": "^0.7.0-rc2"
  },
  "devDependencies": {
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "esbuild": "^0.27.3",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "codemirror",
    "typst",
    "linter",
    "diagnostics",
    "codemirror-extension"
  ],
  "license": "MIT"
}
